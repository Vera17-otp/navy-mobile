        <activity
            android:name=".Home.pertemuan3.ThirdResultActivity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan4.DashboardActivity"
            android:exported="false" />
        <activity
            android:name=".Home.pertemuan4.Custom1Activity"
            android:exported="false" />
        <activity
            android:name=".Home.pertemuan4.Custom2Activity"
            android:exported="false" />

        <activity
            android:name=".Home.Pertemuan5.WebViewActivity"
            android:exported="false" />

        <activity
            android:name=".Home.Pertemuan7.SeventhActivity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan_10.TenthActivity"
            android:exported="false" />

        <activity
            android:name=".Home.pertemuan_13.ThirteenthActivity"

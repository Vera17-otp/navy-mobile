<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A192F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- LOGO -->
        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/pertanahan_logo"
            android:layout_marginTop="20dp"
            android:padding="12dp"
            android:background="@drawable/bg_circle_gold"/>

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERTANAHAN"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#D4AF37"
            android:letterSpacing="0.2"
            android:layout_marginTop="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bina Desa Digital"
            android:textColor="#FFFFFF"
            android:alpha="0.7"
            android:textSize="14sp"
            android:layout_marginBottom="28dp" />

        <!-- CARD UTAMA -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1E2D44"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tentang Aplikasi"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#0A192F" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:background="#D4AF37"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bina Desa Pertanahan merupakan platform integrasi data pertanahan desa yang dirancang untuk mempermudah pemetaan, pendataan lahan, dan pengelolaan aset desa secara digital dan transparan."
                    android:textColor="#4A5568"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp" />

                <!-- BOX VISI -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#F7FAFC"
                    android:padding="16dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Visi"
                        android:textStyle="bold"
                        android:textColor="#0A192F"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mewujudkan digitalisasi pertanahan desa yang transparan dan modern."
                        android:textColor="#4A5568"
                        android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FITUR / KEUNGGULAN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:weightSum="2">

            <!-- ITEM 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#112240">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Lokasi\nStrategis"
                    android:textColor="#FFFFFF"
                    android:textAlignment="center"
                    android:padding="16dp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- ITEM 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#112240">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✔ Data\nTerintegrasi"
                    android:textColor="#FFFFFF"
                    android:textAlignment="center"
                    android:padding="16dp"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- VERSION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="32dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#1E2D44" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Versi 1.0.0"
                android:textColor="#D4AF37"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="16dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#1E2D44" />
        </LinearLayout>

        <!-- FOOTER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="© 2026 Vera Zakia Ramadani"
            android:textColor="#FFFFFF"
            android:alpha="0.4"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
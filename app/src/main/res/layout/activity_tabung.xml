<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Volume Tabung"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#DE736E" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jari-jari (Radius)"
        android:layout_marginTop="20dp"/>

    <EditText
        android:id="@+id/etRadius"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Masukkan jari-jari"
        android:inputType="numberDecimal"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tinggi Tabung"
        android:layout_marginTop="20dp"/>

    <EditText
        android:id="@+id/etTinggi"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Masukkan tinggi"
        android:inputType="numberDecimal"/>

    <Button
        android:id="@+id/btnHitungVolume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hitung Volume"
        android:backgroundTint="#DE736E"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/tvHasil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hasil"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kembali"
        android:textColor="#0000FF"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:padding="10dp"/>

</LinearLayout>